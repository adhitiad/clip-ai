# ──────────────────────────────────────────────
# AI Clipper SaaS — .gitignore
# ──────────────────────────────────────────────

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
MANIFEST

# ── Virtual Environment ───────────────────────
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# ── Environment Variables & Secrets ──────────
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# ── Database ──────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── ML Models (bisa besar, simpan di cloud) ───
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
models/*.onnx
# Tapi tetap track training data ──────────────
!models/training_data.jsonl
!models/.gitkeep

# ── Media Files (video/audio bisa sangat besar)
temp/
output/
clips/
downloads/
*.mp4
*.mp3
*.wav
*.flac
*.aac
*.mkv
*.avi
*.mov
*.webm
*.m4a
*.m4v

# ── Gambar hasil generate ─────────────────────
*.png
*.jpg
*.jpeg
*.gif
*.webp

# ── Subtitle & Transcript tmp ─────────────────
*.vtt
*.srt
*.sbv

# ── Log Files ─────────────────────────────────
*.log
logs/
*.log.*

# ── IDE & Editor ──────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Testing ───────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# ── Type Checkers ─────────────────────────────
.mypy_cache/
.pyright/
.pyrefly/
.dmypy.json
dmypy.json

# ── Jupyter Notebook ──────────────────────────
.ipynb_checkpoints
*.ipynb

# ── Distribution / Packaging ──────────────────
.Python

# ── Celery ────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Docker ────────────────────────────────────
.dockerignore

# ── Node (jika ada frontend Next.js) ─────────
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Misc ──────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
