# Environment Variables Example
# Copy this file to .env and fill in your actual keys.

# --- API KEYS ---
# Dapatkan di https://console.groq.com/
GROQ_API_KEY=gsk_your_actual_key_here

# Dapatkan di https://dashboard.exa.ai/
EXA_API_KEY=exa_your_key_here

# Dapatkan di https://elevenlabs.io/ (Opsional, fallback ke gTTS jika kosong)
ELEVENLABS_API_KEY=your_elevenlabs_key

# Dapatkan di https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=hf_your_token

# Dapatkan di https://app.pinecone.io/
PINECONE_API_KEY=your_pinecone_key

# Dapatkan di https://www.pexels.com/api/ (Wajib untuk B-Roll/Stock Video)
PEXELS_API_KEY=your_pexels_api_key

# --- DATABASE & CACHE ---
# Format: postgresql://[user]:[password]@[host]:[port]/[database_name]
# Contoh: postgresql://postgres:password@localhost:5432/clipper_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/clipper_db
REDIS_URL=redis://localhost:6379/0

# --- SERVER SETTINGS ---
PORT=8000
DEBUG=True
SECRET_KEY=replace_with_a_long_random_secret_key
OWNER_BOOTSTRAP_TOKEN=replace_with_a_strong_bootstrap_token
DUB_ALLOWED_ROOT=temp
# PENTING: Gunakan path absolut di Windows untuk keamanan ekstra (misal: C:\code\clip-ai\temp)
# DUB_ALLOWED_ROOT=C:\path\to\your\temp

# --- AI SETTINGS ---
VIRAL_THRESHOLD=6.5
DEFAULT_GEO=id
