# Environment Variables Example
# Copy this file to .env and fill in your actual keys.

# --- API KEYS ---
# Dapatkan di https://console.groq.com/
GROQ_API_KEY=gsk_your_actual_key_here

# Dapatkan di https://elevenlabs.io/ (Opsional, fallback ke gTTS jika kosong)
ELEVENLABS_API_KEY=your_elevenlabs_key

# Dapatkan di https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=hf_your_token

# Dapatkan di https://app.pinecone.io/
PINECONE_API_KEY=your_pinecone_key

# --- DATABASE & CACHE ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/clipper_db
REDIS_URL=redis://localhost:6373/0

# --- SERVER SETTINGS ---
PORT=8000
DEBUG=True

# --- AI SETTINGS ---
VIRAL_THRESHOLD=6.5
DEFAULT_GEO=id
